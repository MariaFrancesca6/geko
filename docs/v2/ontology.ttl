###  http://www.w3.org/ns/oa#hasBody
<http://www.w3.org/ns/oa#hasBody> rdf:type owl:ObjectProperty ;
                                  rdfs:comment "In GEkO it is the proporty that connects an annotation to its body intended as the ekphrastic textual passage identified by the annotator."@en .


###  http://www.w3.org/ns/oa#hasSelector
<http://www.w3.org/ns/oa#hasSelector> rdf:type owl:ObjectProperty .


###  http://www.w3.org/ns/oa#hasSource
<http://www.w3.org/ns/oa#hasSource> rdf:type owl:ObjectProperty .


###  http://www.w3.org/ns/oa#hasTarget
<http://www.w3.org/ns/oa#hasTarget> rdf:type owl:ObjectProperty ;
                                    rdfs:comment "In GEkO it is the property that connects the textual passage to the informational layer. In GEkO the target is double, the first connecting the text to the digital fascimile in which it is contained, the second connecting the text to the digital reproduction of the visual object described. Typically, the two targets address canvas of a IIIF manifest."@en .


###  http://www.w3.org/ns/oa#motivatedBy
<http://www.w3.org/ns/oa#motivatedBy> rdf:type owl:ObjectProperty .


###  http://www.w3.org/ns/prov#hadMember
<http://www.w3.org/ns/prov#hadMember> rdf:type owl:ObjectProperty ;
                                      rdfs:domain :Ekphrasis ;
                                      rdfs:range <http://www.w3.org/ns/oa#Annotation> .


###  http://www.w3.org/ns/prov#wasGeneratedBy
<http://www.w3.org/ns/prov#wasGeneratedBy> rdf:type owl:ObjectProperty ;
                                           rdfs:domain <http://www.w3.org/ns/oa#Annotation> ;
                                           rdfs:range <http://purl.org/emmedi/hico/InterpretationAct> .


###  https://w3id.org/geko/#hasAuthor
:hasAuthor rdf:type owl:ObjectProperty ;
           owl:inverseOf :isAuthorOf ;
           rdfs:domain :Ekphrasis ;
           rdfs:range <http://xmlns.com/foaf/0.1/Person> ;
           rdfs:comment "The author of the ekphrasis."@en .


###  https://w3id.org/geko/#hasEkphrasticModality
:hasEkphrasticModality rdf:type owl:ObjectProperty ;
                       rdfs:domain <http://www.w3.org/ns/oa#Annotation> ;
                       rdfs:range <http://www.w3.org/2004/02/skos/core#Concept> ;
                       rdfs:comment "Indicates the rhetorical modality recognizable in a textual passage within ekphrastic description"@en .


###  https://w3id.org/geko/#hasIconicReferent
:hasIconicReferent rdf:type owl:ObjectProperty ;
                   owl:inverseOf :isIconicReferentOf ;
                   rdfs:domain :Ekphrasis ;
                   rdfs:range <http://iflastandards.info/ns/lrm/lrmoo/F1_Work> ;
                   rdfs:comment "Links the ekphrasis to the visual artwork described, indetifiable as a Work entity according to FRBR WEMI structure."@en .


###  https://w3id.org/geko/#hasTextualReferent
:hasTextualReferent rdf:type owl:ObjectProperty ;
                    owl:inverseOf :isTextualReferentOf ;
                    rdfs:domain :Ekphrasis ;
                    rdfs:range <http://iflastandards.info/ns/lrm/lrmoo/F2_Expression> ;
                    rdfs:comment "Links the ekphrasis to the specific textual expression containing the description."@en .


###  https://w3id.org/geko/#isAuthorOf
:isAuthorOf rdf:type owl:ObjectProperty ;
            rdfs:domain <http://xmlns.com/foaf/0.1/Person> ;
            rdfs:range :Ekphrasis .


###  https://w3id.org/geko/#isIconicReferentOf
:isIconicReferentOf rdf:type owl:ObjectProperty ;
                    rdfs:domain <http://iflastandards.info/ns/lrm/lrmoo/F1_Work> ;
                    rdfs:range :Ekphrasis .


###  https://w3id.org/geko/#isTextualReferentOf
:isTextualReferentOf rdf:type owl:ObjectProperty ;
                     rdfs:domain <http://iflastandards.info/ns/lrm/lrmoo/F2_Expression> ;
                     rdfs:range :Ekphrasis .


###  https://w3id.org/mlao/#hasAnchor
<https://w3id.org/mlao/#hasAnchor> rdf:type owl:ObjectProperty ;
                                   rdfs:domain <http://www.w3.org/ns/oa#Annotation> ;
                                   rdfs:range <https://w3id.org/mlao/#Anchor> ;
                                   rdfs:comment "This property links the annotation to the conceptual referent of the annotation."@en .


###  https://w3id.org/mlao/#hasConceptualLevel
<https://w3id.org/mlao/#hasConceptualLevel> rdf:type owl:ObjectProperty ;
                                            rdfs:domain <https://w3id.org/mlao/#Anchor> ;
                                            rdfs:range [ rdf:type owl:Class ;
                                                         owl:unionOf ( <https://w3id.org/icon/ontology/IconographicalSubject>
                                                                       <https://w3id.org/icon/ontology/IconologicalSubject>
                                                                       <https://w3id.org/icon/ontology/PreiconographicalSubject>
                                                                     )
                                                       ] .


###  https://w3id.org/mlao/#isAnchoredTo
<https://w3id.org/mlao/#isAnchoredTo> rdf:type owl:ObjectProperty ;
                                      rdfs:domain <https://w3id.org/mlao/#Anchor> ;
                                      rdfs:range <http://www.cidoc-crm.org/cidoc-crm/E1_CRM_Entity> .


