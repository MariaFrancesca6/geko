#################################################################
#    Individuals
#################################################################

###  https://w3id.org/geko/#denotation
:denotation rdf:type owl:NamedIndividual ,
                     <http://www.w3.org/2004/02/skos/core#Concept> ;
            <http://www.w3.org/2004/02/skos/core#definition> "Modality through which the text engages with the referenced visual object, mainly characterized by indexical relations and verbal identification of visible attributes in the scene."@en ;
            <http://www.w3.org/2004/02/skos/core#inScheme> :modalitiesScheme ;
            <http://www.w3.org/2004/02/skos/core#prefLabel> "Denotation"@en .


###  https://w3id.org/geko/#dynamization
:dynamization rdf:type owl:NamedIndividual ,
                       <http://www.w3.org/2004/02/skos/core#Concept> ;
              <http://www.w3.org/2004/02/skos/core#definition> "Modality in which the text engages with the referenced object, mainly by describing the scene characterized by a dynamic movement."@en ;
              <http://www.w3.org/2004/02/skos/core#inScheme> :modalitiesScheme ;
              <http://www.w3.org/2004/02/skos/core#prefLabel> "Dynamization"@en .


###  https://w3id.org/geko/#integration
:integration rdf:type owl:NamedIndividual ,
                      <http://www.w3.org/2004/02/skos/core#Concept> ;
             <http://www.w3.org/2004/02/skos/core#definition> "Modality in which the text engages with the referenced object by integrating the description with elements or symbolic content not directly pertaining to the scene in a strict sense."@en ;
             <http://www.w3.org/2004/02/skos/core#inScheme> :modalitiesScheme ;
             <http://www.w3.org/2004/02/skos/core#prefLabel> "Integration"@en .


###  https://w3id.org/geko/#modalitiesScheme
:modalitiesScheme rdf:type owl:NamedIndividual ,
                           <http://www.w3.org/2004/02/skos/core#ConceptScheme> ;
                  <http://purl.org/dc/terms/title> "Ekphrastic Modalities"@en ;
                  <http://www.w3.org/2004/02/skos/core#definition> "Controlled vocabulary of modalities used in GEkO2 to characterize ekphrastic rhetorical modalities."@en ;
                  <http://www.w3.org/2004/02/skos/core#prefLabel> "Ekphrastic modalities scheme"@en .


