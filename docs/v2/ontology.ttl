###  https://w3id.org/geko/#Ekphrasis
:Ekphrasis rdf:type owl:Class ;
           rdfs:subClassOf <http://www.cidoc-crm.org/cidoc-crm/E33_Linguistic_Object> ,
                           <http://www.w3.org/ns/prov#Collection> ;
           rdfs:comment "The Ekphrasis entity, modeled as a Linguistic Object and a Collection of Annotations."@en .


###  https://w3id.org/geko/#MimeticEkphrasis
:MimeticEkphrasis rdf:type owl:Class ;
                  rdfs:subClassOf :Ekphrasis ;
                  owl:disjointWith :NotionalEkphrasis ;
                  rdfs:comment "An ekphrasis describing a real, physically existing artwork."@en .


###  https://w3id.org/geko/#NotionalEkphrasis
:NotionalEkphrasis rdf:type owl:Class ;
                   rdfs:subClassOf :Ekphrasis ;
                   rdfs:comment "An ekphrasis describing an imagined artwork that exists only within the describing text."@en .


