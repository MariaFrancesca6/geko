    <!-- https://w3id.org/geko/#Ekphrasis -->


    <owl:Class rdf:about="https://w3id.org/geko/#Ekphrasis">
        <rdfs:subClassOf rdf:resource="http://www.cidoc-crm.org/cidoc-crm/E33_Linguistic_Object"/>
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Collection"/>
        <rdfs:comment xml:lang="en">The Ekphrasis entity, modeled as a Linguistic Object and a Collection of Annotations.</rdfs:comment>
    </owl:Class>
    


    <!-- https://w3id.org/geko/#MimeticEkphrasis -->


    <owl:Class rdf:about="https://w3id.org/geko/#MimeticEkphrasis">
        <rdfs:subClassOf rdf:resource="https://w3id.org/geko/#Ekphrasis"/>
        <owl:disjointWith rdf:resource="https://w3id.org/geko/#NotionalEkphrasis"/>
        <rdfs:comment xml:lang="en">An ekphrasis describing a real, physically existing artwork.</rdfs:comment>
    </owl:Class>
    


    <!-- https://w3id.org/geko/#NotionalEkphrasis -->


    <owl:Class rdf:about="https://w3id.org/geko/#NotionalEkphrasis">
        <rdfs:subClassOf rdf:resource="https://w3id.org/geko/#Ekphrasis"/>
        <rdfs:comment xml:lang="en">An ekphrasis describing an imagined artwork that exists only within the describing text.</rdfs:comment>
    </owl:Class>
    


    <!-- https://w3id.org/icon/ontology/IconographicalSubject -->


    <owl:Class rdf:about="https://w3id.org/icon/ontology/IconographicalSubject"/>
    


