    //
    // Individuals
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- https://w3id.org/geko/#denotation -->


    <owl:NamedIndividual rdf:about="https://w3id.org/geko/#denotation">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:definition xml:lang="en">Modality through which the text engages with the referenced visual object, mainly characterized by indexical relations and verbal identification of visible attributes in the scene.</skos:definition>
        <skos:inScheme rdf:resource="https://w3id.org/geko/#modalitiesScheme"/>
        <skos:prefLabel xml:lang="en">Denotation</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/geko/#dynamization -->


    <owl:NamedIndividual rdf:about="https://w3id.org/geko/#dynamization">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:definition xml:lang="en">Modality in which the text engages with the referenced object, mainly by describing the scene characterized by a dynamic movement.</skos:definition>
        <skos:inScheme rdf:resource="https://w3id.org/geko/#modalitiesScheme"/>
        <skos:prefLabel xml:lang="en">Dynamization</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/geko/#integration -->


    <owl:NamedIndividual rdf:about="https://w3id.org/geko/#integration">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:definition xml:lang="en">Modality in which the text engages with the referenced object by integrating the description with elements or symbolic content not directly pertaining to the scene in a strict sense.</skos:definition>
        <skos:inScheme rdf:resource="https://w3id.org/geko/#modalitiesScheme"/>
        <skos:prefLabel xml:lang="en">Integration</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/geko/#modalitiesScheme -->


    <owl:NamedIndividual rdf:about="https://w3id.org/geko/#modalitiesScheme">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#ConceptScheme"/>
        <terms:title xml:lang="en">Ekphrastic Modalities</terms:title>
        <skos:definition xml:lang="en">Controlled vocabulary of modalities used in GEkO2 to characterize ekphrastic rhetorical modalities.</skos:definition>
        <skos:prefLabel xml:lang="en">Ekphrastic modalities scheme</skos:prefLabel>
    </owl:NamedIndividual>
</rdf:RDF>



