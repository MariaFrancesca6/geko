<?xml version="1.0"?>
<rdf:RDF xmlns="https://w3id.org/geko/#"
     xml:base="https://w3id.org/geko/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#"
     xmlns:terms="http://purl.org/dc/terms/">
    <owl:Ontology rdf:about="https://w3id.org/geko/#">
        <owl:versionIRI rdf:resource="https://w3id.org/geko/v2/#"/>
        <terms:creator rdf:resource="https://orcid.org/0009-0003-0559-0409"/>
        <terms:description xml:lang="en">GEkO Ontology describes the phenomenon of ekphrasis along with technical implementation of image-text relations using annotations.</terms:description>
        <terms:title>GEkO Ontology v2</terms:title>
        <owl:priorVersion rdf:resource="https://w3id.org/geko/v1/#"/>
        <owl:versionInfo>2.0.0</owl:versionInfo>
        <skos:changeNote xml:lang="en">**Version 2 Changelog** Introduction of four aspects: - hasForm ObjectProperty deprecated; NotionalEkphrasis and MimeticEkphrasis classes become subClassOf Ekphrasis - Aligment of Ekphrasis with CIDOC-CRM instantiated as subClassOf E33_Linguistic_Object - Transition to SKOS Concept to identify the ekphrastic modelities (denotation, dynamization, integration), prior modeled as classes - Definition of an ObjectProperty hasAuthor for signaling the author of Ekphrasis, more specifical than dct:creator</skos:changeNote>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://purl.org/dc/terms/creator -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/creator"/>
    


    <!-- http://purl.org/dc/terms/description -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/description"/>
    


    <!-- http://purl.org/dc/terms/title -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/title"/>
    


    <!-- http://www.w3.org/2004/02/skos/core#changeNote -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#changeNote"/>
    


    <!-- http://www.w3.org/2004/02/skos/core#definition -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#definition"/>
    


    <!-- http://www.w3.org/2004/02/skos/core#inScheme -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#inScheme"/>
    


    <!-- http://www.w3.org/2004/02/skos/core#prefLabel -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#prefLabel"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://purl.org/dc/terms/isPartOf -->


    <owl:ObjectProperty rdf:about="http://purl.org/dc/terms/isPartOf"/>
    


    <!-- http://purl.org/emmedi/hico/hasInterpretationCriterion -->


    <owl:ObjectProperty rdf:about="http://purl.org/emmedi/hico/hasInterpretationCriterion"/>
    


    <!-- http://purl.org/emmedi/hico/hasInterpretationType -->


    <owl:ObjectProperty rdf:about="http://purl.org/emmedi/hico/hasInterpretationType"/>
    


    <!-- http://www.w3.org/ns/oa#hasBody -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/oa#hasBody">
        <rdfs:comment xml:lang="en">In GEkO it is the proporty that connects an annotation to its body intended as the ekphrastic textual passage identified by the annotator.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/ns/oa#hasSelector -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/oa#hasSelector"/>
    


    <!-- http://www.w3.org/ns/oa#hasSource -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/oa#hasSource"/>
    


    <!-- http://www.w3.org/ns/oa#hasTarget -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/oa#hasTarget">
        <rdfs:comment xml:lang="en">In GEkO it is the property that connects the textual passage to the informational layer. In GEkO the target is double, the first connecting the text to the digital fascimile in which it is contained, the second connecting the text to the digital reproduction of the visual object described. Typically, the two targets address canvas of a IIIF manifest.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/ns/oa#motivatedBy -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/oa#motivatedBy"/>
    


    <!-- http://www.w3.org/ns/prov#hadMember -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/prov#hadMember">
        <rdfs:domain rdf:resource="https://w3id.org/geko/#Ekphrasis"/>
        <rdfs:range rdf:resource="http://www.w3.org/ns/oa#Annotation"/>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/ns/prov#wasGeneratedBy -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/prov#wasGeneratedBy">
        <rdfs:domain rdf:resource="http://www.w3.org/ns/oa#Annotation"/>
        <rdfs:range rdf:resource="http://purl.org/emmedi/hico/InterpretationAct"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/geko/#hasAuthor -->


    <owl:ObjectProperty rdf:about="https://w3id.org/geko/#hasAuthor">
        <owl:inverseOf rdf:resource="https://w3id.org/geko/#isAuthorOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/geko/#Ekphrasis"/>
        <rdfs:range rdf:resource="http://xmlns.com/foaf/0.1/Person"/>
        <rdfs:comment xml:lang="en">The author of the ekphrasis.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/geko/#hasEkphrasticModality -->


    <owl:ObjectProperty rdf:about="https://w3id.org/geko/#hasEkphrasticModality">
        <rdfs:domain rdf:resource="http://www.w3.org/ns/oa#Annotation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdfs:comment xml:lang="en">Indicates the rhetorical modality recognizable in a textual passage within ekphrastic description</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/geko/#hasIconicReferent -->


    <owl:ObjectProperty rdf:about="https://w3id.org/geko/#hasIconicReferent">
        <owl:inverseOf rdf:resource="https://w3id.org/geko/#isIconicReferentOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/geko/#Ekphrasis"/>
        <rdfs:range rdf:resource="http://iflastandards.info/ns/lrm/lrmoo/F1_Work"/>
        <rdfs:comment xml:lang="en">Links the ekphrasis to the visual artwork described, indetifiable as a Work entity according to FRBR WEMI structure.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/geko/#hasTextualReferent -->


    <owl:ObjectProperty rdf:about="https://w3id.org/geko/#hasTextualReferent">
        <owl:inverseOf rdf:resource="https://w3id.org/geko/#isTextualReferentOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/geko/#Ekphrasis"/>
        <rdfs:range rdf:resource="http://iflastandards.info/ns/lrm/lrmoo/F2_Expression"/>
        <rdfs:comment xml:lang="en">Links the ekphrasis to the specific textual expression containing the description.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/geko/#isAuthorOf -->


    <owl:ObjectProperty rdf:about="https://w3id.org/geko/#isAuthorOf">
        <rdfs:domain rdf:resource="http://xmlns.com/foaf/0.1/Person"/>
        <rdfs:range rdf:resource="https://w3id.org/geko/#Ekphrasis"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/geko/#isIconicReferentOf -->


    <owl:ObjectProperty rdf:about="https://w3id.org/geko/#isIconicReferentOf">
        <rdfs:domain rdf:resource="http://iflastandards.info/ns/lrm/lrmoo/F1_Work"/>
        <rdfs:range rdf:resource="https://w3id.org/geko/#Ekphrasis"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/geko/#isTextualReferentOf -->


    <owl:ObjectProperty rdf:about="https://w3id.org/geko/#isTextualReferentOf">
        <rdfs:domain rdf:resource="http://iflastandards.info/ns/lrm/lrmoo/F2_Expression"/>
        <rdfs:range rdf:resource="https://w3id.org/geko/#Ekphrasis"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/mlao/#hasAnchor -->


    <owl:ObjectProperty rdf:about="https://w3id.org/mlao/#hasAnchor">
        <rdfs:domain rdf:resource="http://www.w3.org/ns/oa#Annotation"/>
        <rdfs:range rdf:resource="https://w3id.org/mlao/#Anchor"/>
        <rdfs:comment xml:lang="en">This property links the annotation to the conceptual referent of the annotation.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/mlao/#hasConceptualLevel -->


    <owl:ObjectProperty rdf:about="https://w3id.org/mlao/#hasConceptualLevel">
        <rdfs:domain rdf:resource="https://w3id.org/mlao/#Anchor"/>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/icon/ontology/IconographicalSubject"/>
                    <rdf:Description rdf:about="https://w3id.org/icon/ontology/IconologicalSubject"/>
                    <rdf:Description rdf:about="https://w3id.org/icon/ontology/PreiconographicalSubject"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/mlao/#isAnchoredTo -->


    <owl:ObjectProperty rdf:about="https://w3id.org/mlao/#isAnchoredTo">
        <rdfs:domain rdf:resource="https://w3id.org/mlao/#Anchor"/>
        <rdfs:range rdf:resource="http://www.cidoc-crm.org/cidoc-crm/E1_CRM_Entity"/>
    </owl:ObjectProperty>
    


