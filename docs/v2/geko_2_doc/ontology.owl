    <owl:Class rdf:about="https://w3id.org/icon/ontology/IconologicalSubject"/>
    


    <!-- https://w3id.org/icon/ontology/PreiconographicalSubject -->


    <owl:Class rdf:about="https://w3id.org/icon/ontology/PreiconographicalSubject"/>
    


    <!-- https://w3id.org/mlao/#Anchor -->


    <owl:Class rdf:about="https://w3id.org/mlao/#Anchor"/>
    


    <!-- 
