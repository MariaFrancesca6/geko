}, {
  "@id" : "https://w3id.org/geko/#",
  "@type" : [ "http://www.w3.org/2002/07/owl#Ontology" ],
  "http://purl.org/dc/terms/creator" : [ {
    "@id" : "https://orcid.org/0009-0003-0559-0409"
  } ],
  "http://purl.org/dc/terms/description" : [ {
    "@language" : "en",
    "@value" : "GEkO Ontology describes the phenomenon of ekphrasis along with technical implementation of image-text relations using annotations."
  } ],
  "http://purl.org/dc/terms/title" : [ {
    "@value" : "GEkO Ontology v2"
  } ],
  "http://www.w3.org/2002/07/owl#priorVersion" : [ {
    "@id" : "https://w3id.org/geko/v1/#"
  } ],
  "http://www.w3.org/2002/07/owl#versionIRI" : [ {
    "@id" : "https://w3id.org/geko/v2/#"
  } ],
  "http://www.w3.org/2002/07/owl#versionInfo" : [ {
    "@value" : "2.0.0"
  } ],
  "http://www.w3.org/2004/02/skos/core#changeNote" : [ {
    "@language" : "en",
    "@value" : "**Version 2 Changelog** Introduction of four aspects: - hasForm ObjectProperty deprecated; NotionalEkphrasis and MimeticEkphrasis classes become subClassOf Ekphrasis - Aligment of Ekphrasis with CIDOC-CRM instantiated as subClassOf E33_Linguistic_Object - Transition to SKOS Concept to identify the ekphrastic modelities (denotation, dynamization, integration), prior modeled as classes - Definition of an ObjectProperty hasAuthor for signaling the author of Ekphrasis, more specifical than dct:creator"
  } ]
}, {
  "@id" : "https://w3id.org/geko/#Ekphrasis",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "The Ekphrasis entity, modeled as a Linguistic Object and a Collection of Annotations."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.cidoc-crm.org/cidoc-crm/E33_Linguistic_Object"
  }, {
    "@id" : "http://www.w3.org/ns/prov#Collection"
  } ]
}, {
  "@id" : "https://w3id.org/geko/#MimeticEkphrasis",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "An ekphrasis describing a real, physically existing artwork."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/geko/#Ekphrasis"
  } ],
  "http://www.w3.org/2002/07/owl#disjointWith" : [ {
    "@id" : "https://w3id.org/geko/#NotionalEkphrasis"
  } ]
}, {
  "@id" : "https://w3id.org/geko/#NotionalEkphrasis",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "An ekphrasis describing an imagined artwork that exists only within the describing text."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/geko/#Ekphrasis"
  } ]
}, {
  "@id" : "https://w3id.org/geko/#denotation",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2004/02/skos/core#Concept"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "Modality through which the text engages with the referenced visual object, mainly characterized by indexical relations and verbal identification of visible attributes in the scene."
  } ],
  "http://www.w3.org/2004/02/skos/core#inScheme" : [ {
    "@id" : "https://w3id.org/geko/#modalitiesScheme"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Denotation"
  } ]
}, {
  "@id" : "https://w3id.org/geko/#dynamization",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2004/02/skos/core#Concept"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "Modality in which the text engages with the referenced object, mainly by describing the scene characterized by a dynamic movement."
  } ],
  "http://www.w3.org/2004/02/skos/core#inScheme" : [ {
    "@id" : "https://w3id.org/geko/#modalitiesScheme"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Dynamization"
  } ]
}, {
  "@id" : "https://w3id.org/geko/#hasAuthor",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "The author of the ekphrasis."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://w3id.org/geko/#Ekphrasis"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://xmlns.com/foaf/0.1/Person"
  } ],
  "http://www.w3.org/2002/07/owl#inverseOf" : [ {
    "@id" : "https://w3id.org/geko/#isAuthorOf"
  } ]
}, {
  "@id" : "https://w3id.org/geko/#hasEkphrasticModality",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Indicates the rhetorical modality recognizable in a textual passage within ekphrastic description"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "http://www.w3.org/ns/oa#Annotation"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://www.w3.org/2004/02/skos/core#Concept"
  } ]
}, {
  "@id" : "https://w3id.org/geko/#hasIconicReferent",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Links the ekphrasis to the visual artwork described, indetifiable as a Work entity according to FRBR WEMI structure."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://w3id.org/geko/#Ekphrasis"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://iflastandards.info/ns/lrm/lrmoo/F1_Work"
  } ],
  "http://www.w3.org/2002/07/owl#inverseOf" : [ {
    "@id" : "https://w3id.org/geko/#isIconicReferentOf"
  } ]
}, {
  "@id" : "https://w3id.org/geko/#hasTextualReferent",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Links the ekphrasis to the specific textual expression containing the description."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://w3id.org/geko/#Ekphrasis"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://iflastandards.info/ns/lrm/lrmoo/F2_Expression"
  } ],
  "http://www.w3.org/2002/07/owl#inverseOf" : [ {
    "@id" : "https://w3id.org/geko/#isTextualReferentOf"
  } ]
}, {
  "@id" : "https://w3id.org/geko/#integration",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2004/02/skos/core#Concept"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "Modality in which the text engages with the referenced object by integrating the description with elements or symbolic content not directly pertaining to the scene in a strict sense."
  } ],
  "http://www.w3.org/2004/02/skos/core#inScheme" : [ {
    "@id" : "https://w3id.org/geko/#modalitiesScheme"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Integration"
  } ]
}, {
  "@id" : "https://w3id.org/geko/#isAuthorOf",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "http://xmlns.com/foaf/0.1/Person"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "https://w3id.org/geko/#Ekphrasis"
  } ]
}, {
  "@id" : "https://w3id.org/geko/#isIconicReferentOf",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "http://iflastandards.info/ns/lrm/lrmoo/F1_Work"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "https://w3id.org/geko/#Ekphrasis"
  } ]
}, {
  "@id" : "https://w3id.org/geko/#isTextualReferentOf",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "http://iflastandards.info/ns/lrm/lrmoo/F2_Expression"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "https://w3id.org/geko/#Ekphrasis"
  } ]
}, {
  "@id" : "https://w3id.org/geko/#modalitiesScheme",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://purl.org/dc/terms/title" : [ {
    "@language" : "en",
    "@value" : "Ekphrastic Modalities"
  } ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2004/02/skos/core#ConceptScheme"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "Controlled vocabulary of modalities used in GEkO2 to characterize ekphrastic rhetorical modalities."
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Ekphrastic modalities scheme"
  } ]
}, {
  "@id" : "https://w3id.org/icon/ontology/IconographicalSubject",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ]
}, {
